layout_mode = 2
theme_override_colors/font_color = Color(0.957, 0.722, 0.376, 1)
horizontal_alignment = 1

[connection signal="pressed" from="Page/Layout/TopBar/MainMenuButton" to="." method="_on_main_menu_pressed"]
[connection signal="pressed" from="Page/Layout/Body/Sidebar/Margin/Navigation/RecruitingButton" to="." method="_on_section_pressed" binds= ["Recruiting"]]
[connection signal="pressed" from="Page/Layout/Body/Sidebar/Margin/Navigation/StaffButton" to="." method="_on_section_pressed" binds= ["Staff"]]
[connection signal="pressed" from="Page/Layout/Body/Sidebar/Margin/Navigation/FinancesButton" to="." method="_on_section_pressed" binds= ["Finances"]]
[connection signal="pressed" from="Page/Layout/Body/Sidebar/Margin/Navigation/ShowDesignButton" to="." method="_on_section_pressed" binds= ["Show Design"]]
[connection signal="pressed" from="Page/Layout/Body/Sidebar/Margin/Navigation/CalendarButton" to="." method="_on_section_pressed" binds= ["Calendar"]]

