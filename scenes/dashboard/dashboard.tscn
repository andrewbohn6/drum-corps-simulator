horizontal_alignment = 1

[node name="WelcomePanel" type="PanelContainer" parent="Page/Layout/Body/DashboardContent"]
layout_mode = 2
size_flags_vertical = 3

[node name="Content" type="VBoxContainer" parent="Page/Layout/Body/DashboardContent/WelcomePanel"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Page/Layout/Body/DashboardContent/WelcomePanel/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.94, 0.97, 1, 1)
theme_override_font_sizes/font_size = 28
text = "Your journey starts here."
horizontal_alignment = 1

[node name="Body" type="Label" parent="Page/Layout/Body/DashboardContent/WelcomePanel/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.52, 0.61, 0.71, 1)
text = "Build your staff, recruit the membership, and design a show worthy of finals night."
horizontal_alignment = 1
autowrap_mode = 2

[node name="StatusLabel" type="Label" parent="Page/Layout/Body/DashboardContent/WelcomePanel/Content"]
